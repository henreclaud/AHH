# Copy this file to .env for local development.
# Never commit .env — it contains secrets.

# The ID of the Google Calendar Peter manages shifts on.
# Find it in Google Calendar → Settings → (your calendar) → Calendar ID
# Looks like: abc123xyz@group.calendar.google.com
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# The ID of the Google Sheet used for signups.
# It's the long string in the sheet URL between /d/ and /edit
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your-sheet-id-here

# The full contents of the service account credentials JSON file,
# pasted as a single line.
# Get this from Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON
# To convert the file to a single line run:
#   cat your-credentials.json | tr -d '\n'   (then paste the output here)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
